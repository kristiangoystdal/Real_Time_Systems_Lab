 20305                           ;Config register CONFIG1 @ 0x8007
 20306                           ;	External Oscillator mode selection bits
 20307                           ;	FEXTOSC = ECH, EC above 8MHz; PFM set to high power
 20308                           ;	Power-up default value for COSC bits
 20309                           ;	RSTOSC = HFINT32, HFINTOSC with OSCFRQ= 32 MHz and CDIV = 1:1
 20310                           ;	Clock Out Enable bit
 20311                           ;	CLKOUTEN = OFF, CLKOUT function is disabled; i/o or oscillator function on OSC2
 20312                           ;	Clock Switch Enable bit
 20313                           ;	CSWEN = ON, Writing to NOSC and NDIV is allowed
 20314                           ;	Fail-Safe Clock Monitor Enable bit
 20315                           ;	FCMEN = ON, FSCM timer enabled
 20316     8007                     	org	32775
 20317     8007  3F8F               	dw	16271
 20318                           
 20319                           ;Config register CONFIG2 @ 0x8008
 20320                           ;	Master Clear Enable bit
 20321                           ;	MCLRE = ON, MCLR pin is Master Clear function
 20322                           ;	Power-up Timer Enable bit
 20323                           ;	PWRTE = OFF, PWRT disabled
 20324                           ;	Low-Power BOR enable bit
 20325                           ;	LPBOREN = OFF, ULPBOR disabled
 20326                           ;	Brown-out reset enable bits
 20327                           ;	BOREN = ON, Brown-out Reset Enabled, SBOREN bit is ignored
 20328                           ;	Brown-out Reset Voltage Selection
 20329                           ;	BORV = LO, Brown-out Reset Voltage (VBOR) set to 1.9V on LF, and 2.45V on F Devices
 20330                           ;	Zero-cross detect disable
 20331                           ;	ZCD = OFF, Zero-cross detect circuit is disabled at POR.
 20332                           ;	Peripheral Pin Select one-way control
 20333                           ;	PPS1WAY = ON, The PPSLOCK bit can be cleared and set only once in software
 20334                           ;	Stack Overflow/Underflow Reset Enable bit
