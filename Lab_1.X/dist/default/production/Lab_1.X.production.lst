 14419                           ;	FEXTOSC = ECH, EC above 8MHz; PFM set to high power
 14420                           ;	Power-up default value for COSC bits
 14421                           ;	RSTOSC = HFINT32, HFINTOSC with OSCFRQ= 32 MHz and CDIV = 1:1
 14422                           ;	Clock Out Enable bit
 14423                           ;	CLKOUTEN = OFF, CLKOUT function is disabled; i/o or oscillator function on OSC2
 14424                           ;	Clock Switch Enable bit
 14425                           ;	CSWEN = ON, Writing to NOSC and NDIV is allowed
 14426                           ;	Fail-Safe Clock Monitor Enable bit
 14427                           ;	FCMEN = ON, FSCM timer enabled
 14428     8007                     	org	32775
 14429     8007  3F8F               	dw	16271
 14430                           
 14431                           ;Config register CONFIG2 @ 0x8008
 14432                           ;	Master Clear Enable bit
 14433                           ;	MCLRE = ON, MCLR pin is Master Clear function
 14434                           ;	Power-up Timer Enable bit
 14435                           ;	PWRTE = OFF, PWRT disabled
 14436                           ;	Low-Power BOR enable bit
 14437                           ;	LPBOREN = OFF, ULPBOR disabled
 14438                           ;	Brown-out reset enable bits
 14439                           ;	BOREN = ON, Brown-out Reset Enabled, SBOREN bit is ignored
 14440                           ;	Brown-out Reset Voltage Selection
 14441                           ;	BORV = LO, Brown-out Reset Voltage (VBOR) set to 1.9V on LF, and 2.45V on F Devices
 14442                           ;	Zero-cross detect disable
 14443                           ;	ZCD = OFF, Zero-cross detect circuit is disabled at POR.
 14444                           ;	Peripheral Pin Select one-way control
 14445                           ;	PPS1WAY = ON, The PPSLOCK bit can be cleared and set only once in software
 14446                           ;	Stack Overflow/Underflow Reset Enable bit
 14447                           ;	STVREN = ON, Stack Overflow or Underflow will cause a reset
 14448                           ;	Background Debugger
 14449                           ;	DEBUG = 0x1, unprogrammed default
 14450     8008                     	org	32776
 14451     8008  3FFF               	dw	16383
 14452                           
 14453                           ;Config register CONFIG3 @ 0x8009
 14454                           ;	WDT Period Select bits
 14455                           ;	WDTCPS = WDTCPS_31, Divider ratio 1:65536; software control of WDTPS
 14456                           ;	WDT operating mode
 14457                           ;	WDTE = OFF, WDT Disabled, SWDTEN is ignored
 14458                           ;	WDT Window Select bits
 14459                           ;	WDTCWS = WDTCWS_7, window always open (100%); software control; keyed access not requi
      +                          red
 14460                           ;	WDT input clock selector
 14461                           ;	WDTCCS = SC, Software Control
 14462     8009                     	org	32777
 14463     8009  3F9F               	dw	16287
