 14421                           ;	RSTOSC = HFINT32, HFINTOSC with OSCFRQ= 32 MHz and CDIV = 1:1
 14422                           ;	Clock Out Enable bit
 14423                           ;	CLKOUTEN = OFF, CLKOUT function is disabled; i/o or oscillator function on OSC2
 14424                           ;	Clock Switch Enable bit
 14425                           ;	CSWEN = ON, Writing to NOSC and NDIV is allowed
 14426                           ;	Fail-Safe Clock Monitor Enable bit
 14427                           ;	FCMEN = ON, FSCM timer enabled
